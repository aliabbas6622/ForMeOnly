<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <!-- Glowing Background Effect or Visuals -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Alarm Icon with simple pulse feel -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@android:drawable/ic_lock_idle_alarm"
            app:tint="#F59E0B"
            android:layout_marginBottom="24dp" />

        <!-- Large Digital Clock -->
        <TextView
            android:id="@+id/ringClockText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07:00"
            android:textColor="#FFFFFF"
            android:textSize="72sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-thin" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alarm_ringing"
            android:textColor="#88FFFFFF"
            android:textSize="18sp"
            android:layout_marginTop="8dp"
            android:textAllCaps="true"
            android:letterSpacing="0.2" />

        <!-- Message Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#1F1F1F"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="160dp"
                android:padding="20dp">

                <TextView
                    android:id="@+id/ringMessageText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Good morning! It's time to wake up."
                    android:textColor="#E0E0E0"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Dismiss Button at the Bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/dismissButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="32dp"
        android:text="@string/dismiss"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:backgroundTint="#EF4444"
        app:cornerRadius="32dp"
        app:elevation="4dp" />

</RelativeLayout>
